<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <include
            android:id="@+id/toolbar_include"
            layout="@layout/toolbar_portal" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            app:elevation="16dp"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconSize="22dp"
            app:itemPaddingTop="12dp"
            app:itemPaddingBottom="12dp"
            app:itemIconTint="@color/bnv_selector"
            app:itemTextColor="@color/bnv_selector" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar_include"
            android:layout_above="@id/bottom_navigation"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section 1: Laporan Kelas Header -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#ECF0F1">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Laporan Kelas"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#2C3E50"/>
                                <TextView
                                    android:id="@+id/tv_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Statistik capaian bulanan"
                                    android:textSize="11sp"
                                    android:textColor="#7F8C8D"/>
                            </LinearLayout>

                            <Button
                                android:id="@+id/btnExportPdf"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_alignParentEnd="true"
                                android:text="PDF"
                                android:textSize="12sp"
                                android:backgroundTint="#2C3E50"
                                android:textColor="#FFFFFF"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp"
                                android:minHeight="0dp"
                                android:paddingHorizontal="16dp"
                                app:icon="@android:drawable/ic_menu_save"
                                app:iconSize="14dp"
                                app:iconGravity="textStart"/>
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:weightSum="2"
                            android:baselineAligned="false">

                            <!-- Filter Bulan -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_rounded_white_border"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="8dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@android:drawable/ic_menu_today"
                                    app:tint="#7F8C8D"
                                    android:contentDescription="Filter Bulan" />

                                <Spinner
                                    android:id="@+id/spinner_month"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@null"
                                    android:paddingStart="4dp"
                                    android:paddingEnd="0dp"
                                    android:overlapAnchor="false"/>

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@android:drawable/arrow_down_float"
                                    app:tint="#7F8C8D"
                                    android:contentDescription="Dropdown arrow" />
                            </LinearLayout>

                            <!-- Filter Kelas -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="42dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_rounded_white_border"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="8dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_siswa"
                                    app:tint="#7F8C8D"
                                    android:contentDescription="Filter Kelas" />

                                <Spinner
                                    android:id="@+id/spinner_class"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:background="@null"
                                    android:paddingStart="4dp"
                                    android:paddingEnd="0dp"
                                    android:overlapAnchor="false"/>

                                <ImageView
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:src="@android:drawable/arrow_down_float"
                                    app:tint="#7F8C8D"
                                    android:contentDescription="Dropdown arrow" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#DDE4E9"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:id="@+id/container_graph"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:paddingTop="20dp"
                            android:weightSum="5">
                            <!-- Bars will be added programmatically -->
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp"
                            android:gravity="center">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Kognitif" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Sosial" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Motorik" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Komunikasi" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bina Diri" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 2: Rekap Kehadiran -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#ECF0F1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rekap kehadiran kelas"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"
                            android:layout_marginBottom="12dp"/>

                        <TableLayout
                            android:id="@+id/table_attendance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:stretchColumns="0">
                            <TableRow android:layout_marginBottom="8dp">
                                <TextView android:text="Siswa" android:textSize="11sp" android:textColor="#7F8C8D"/>
                                <TextView android:text="Hadir" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center" android:layout_width="50dp"/>
                                <TextView android:text="Sakit" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center" android:layout_width="50dp"/>
                                <TextView android:text="Izin" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center" android:layout_width="50dp"/>
                                <TextView android:text="Alpha" android:textSize="11sp" android:textColor="#7F8C8D" android:gravity="center" android:layout_width="50dp"/>
                            </TableRow>
                            <View android:layout_height="1dp" android:background="#BDC3C7" android:layout_marginBottom="8dp"/>

                            <!-- Rows will be added programmatically -->
                        </TableLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section 3: Catatan Naratif -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#ECF0F1">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Catatan naratif"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ringkasan pencapaian kelas"
                            android:textSize="11sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginBottom="12dp"/>

                        <EditText
                            android:id="@+id/et_narrative_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="120dp"
                            android:gravity="top"
                            android:padding="12dp"
                            android:background="@drawable/bg_rounded_gray"
                            android:backgroundTint="#7F8C8D"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:hint="Tulis catatan naratif di sini..."
                            android:textColorHint="#BDC3C7"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:gravity="center">
                            <Button
                                android:id="@+id/btn_save"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="Simpan"
                                android:textSize="14sp"
                                android:backgroundTint="#7F8C8D"
                                android:textColor="#FFFFFF"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp"
                                android:layout_marginEnd="8dp"/>
                            <Button
                                android:id="@+id/btn_preview"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="Preview"
                                android:textSize="14sp"
                                android:backgroundTint="#7F8C8D"
                                android:textColor="#FFFFFF"
                                android:textAllCaps="false"
                                app:cornerRadius="8dp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <!-- Side Navigation -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header_main" />

</androidx.drawerlayout.widget.DrawerLayout>