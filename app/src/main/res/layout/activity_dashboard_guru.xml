<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Main Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <!-- Header -->
        <include
            android:id="@+id/toolbar_include"
            layout="@layout/toolbar_portal" />

        <!-- Bottom Navigation -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="#FFFFFF"
            app:elevation="16dp"
            app:menu="@menu/bottom_nav_menu"
            app:labelVisibilityMode="labeled"
            app:itemIconSize="22dp"
            app:itemPaddingTop="12dp"
            app:itemPaddingBottom="12dp"
            app:itemIconTint="@color/bnv_selector"
            app:itemTextColor="@color/bnv_selector" />

        <!-- Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar_include"
            android:layout_above="@id/bottom_navigation"
            android:clipToPadding="false"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas Saya"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"/>

                <!-- Tab Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <Button
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Kelas VII-A"
                        android:textSize="11sp"
                        android:backgroundTint="#2C3E50"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="8dp"
                        android:textAllCaps="false"
                        app:cornerRadius="18dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                    <Button
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="Kelas VII-B"
                        android:textSize="11sp"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="#2C3E50"
                        android:textAllCaps="false"
                        app:cornerRadius="18dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:weightSum="4">

                    <LinearLayout
                        android:id="@+id/stat_total_siswa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Siswa" android:textSize="9sp" android:textColor="#95A5A6"/>
                        <TextView android:id="@+id/tv_total_siswa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="16sp" android:textColor="#2C3E50"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Input Harian" android:textSize="9sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9" android:textStyle="bold" android:textSize="16sp" android:textColor="#2E7D32"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Perlu Perhatian" android:textSize="9sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textStyle="bold" android:textSize="16sp" android:textColor="#E67E22"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pesan Baru" android:textSize="9sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textStyle="bold" android:textSize="16sp" android:textColor="#2980B9"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Tugas Pending -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tugas Pending"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginTop="20dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#FFFFFF">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Input Absensi VII-A - 3 siswa belum diinput" android:textSize="12sp" android:textColor="#2C3E50"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Deadline: 15 November 2024" android:textSize="10sp" android:textColor="#95A5A6" android:layout_marginBottom="8dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• Laporan Bulanan - Jatuh Tempo" android:textSize="12sp" android:textColor="#2C3E50"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Deadline: 20 November 2024" android:textSize="10sp" android:textColor="#95A5A6" android:layout_marginBottom="8dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="• PPI Review - Gita M." android:textSize="12sp" android:textColor="#2C3E50"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  Jadwalkan Minggu Ini" android:textSize="10sp" android:textColor="#95A5A6"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Siswa Perlu Perhatian -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siswa perlu perhatian"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginTop="20dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:id="@+id/container_perlu_perhatian"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFFFFF">
                        <!-- Items will be added dynamically -->
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Notifikasi -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifikasi"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginTop="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#ECF0F1"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laporan bulanan tersedia" android:textSize="12sp" android:textStyle="bold" android:textColor="#2C3E50"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Laporan Semester 2024 telah dirilis" android:textSize="10sp" android:textColor="#95A5A6"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kemarin" android:textSize="9sp" android:textColor="#BDC3C7"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingVertical="8dp">
                        <View android:layout_width="32dp" android:layout_height="32dp" android:background="#ECF0F1"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jadwal Konsultasi" android:textSize="12sp" android:textStyle="bold" android:textColor="#2C3E50"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Diskusi bersama Ibu Sari (Wali Andi)" android:textSize="10sp" android:textColor="#95A5A6"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 menit" android:textSize="9sp" android:textColor="#BDC3C7"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <!-- Side Navigation -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/nav_header_main" />

</androidx.drawerlayout.widget.DrawerLayout>