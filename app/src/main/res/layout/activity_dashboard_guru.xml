<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Custom Header -->
    <include layout="@layout/toolbar_portal" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ringkasan Kelas"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"/>

            <!-- Tab Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Kelas VII-A"
                    android:textSize="11sp"
                    android:backgroundTint="#2C3E50"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"/>

                <Button
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Kelas VII-B"
                    android:textSize="11sp"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#2C3E50"
                    android:textAllCaps="false"
                    app:cornerRadius="20dp"/>
            </LinearLayout>

            <!-- Stats -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="4"
                    android:background="#FFFFFF">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Siswa" android:textSize="10sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14" android:textStyle="bold" android:textSize="18sp" android:textColor="#2C3E50"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Input" android:textSize="10sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9" android:textStyle="bold" android:textSize="18sp" android:textColor="#2E7D32"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Atensi" android:textSize="10sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textStyle="bold" android:textSize="18sp" android:textColor="#E67E22"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chat" android:textSize="10sp" android:textColor="#95A5A6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textStyle="bold" android:textSize="18sp" android:textColor="#2980B9"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Siswa Perlu Perhatian -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Siswa Perlu Perhatian"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginTop="24dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="#FFFFFF">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_circle_gray" android:backgroundTint="#ECF0F1"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gita M." android:textStyle="bold" android:textColor="#2C3E50"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kognitif 45%, Kehadiran 70%" android:textSize="11sp" android:textColor="#E74C3C"/>
                    </LinearLayout>
                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Detail"
                        android:textSize="11sp"
                        android:textColor="#2C3E50"
                        android:backgroundTint="#F2F4F7"
                        android:textAllCaps="false"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="16dp"
                        style="?android:attr/borderlessButtonStyle"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>