<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <include layout="@layout/toolbar_portal" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail PPI: Andi Rizky"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Pembelajaran Individual"
                android:textSize="12sp"
                android:textColor="#7F8C8D"
                android:layout_marginBottom="20dp"/>

            <!-- Grid Target -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="4dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:padding="16dp" android:orientation="vertical" android:background="#FFFFFF">
                        <TextView android:text="Kognitif" android:textStyle="bold" android:textSize="12sp" android:textColor="#2C3E50"/>
                        <TextView android:text="Membaca KV-KV &amp; menulis nama." android:textSize="11sp" android:textColor="#7F8C8D" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:layout_margin="4dp"
                    app:cardCornerRadius="12dp" app:cardElevation="2dp">
                    <LinearLayout android:padding="16dp" android:orientation="vertical" android:background="#FFFFFF">
                        <TextView android:text="Motorik" android:textStyle="bold" android:textSize="12sp" android:textColor="#2C3E50"/>
                        <TextView android:text="Memegang kuas &amp; pola gunting." android:textSize="11sp" android:textColor="#7F8C8D" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Progres Terkini"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0">
                    <TableRow android:background="#2C3E50" android:padding="2dp">
                        <TextView android:text="Bulan / Minggu" android:padding="14dp" android:textSize="11sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:text="Aspek" android:padding="14dp" android:textSize="11sp" android:textStyle="bold" android:textColor="#FFFFFF" android:gravity="center"/>
                        <TextView android:text="Nilai" android:padding="14dp" android:textSize="11sp" android:textStyle="bold" android:textColor="#FFFFFF" android:gravity="center"/>
                    </TableRow>

                    <TableRow android:padding="2dp" android:background="#FFFFFF">
                        <TextView android:text="Nov - Mng 1" android:padding="14dp" android:textSize="11sp" android:textColor="#333333"/>
                        <TextView android:text="Kognitif" android:padding="14dp" android:textSize="11sp" android:gravity="center" android:textColor="#7F8C8D"/>
                        <TextView android:text="45%" android:padding="14dp" android:textSize="11sp" android:gravity="center" android:textColor="#E67E22" android:textStyle="bold"/>
                    </TableRow>
                    <View android:layout_height="1dp" android:background="#F2F4F7" />

                    <TableRow android:padding="2dp" android:background="#FFFFFF">
                        <TextView android:text="Nov - Mng 2" android:padding="14dp" android:textSize="11sp" android:textColor="#333333"/>
                        <TextView android:text="Motorik" android:padding="14dp" android:textSize="11sp" android:gravity="center" android:textColor="#7F8C8D"/>
                        <TextView android:text="75%" android:padding="14dp" android:textSize="11sp" android:gravity="center" android:textColor="#2E7D32" android:textStyle="bold"/>
                    </TableRow>
                </TableLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="*Nilai capaian dihitung otomatis dari rata-rata input harian"
                android:textSize="10sp"
                android:textColor="#7F8C8D"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:textStyle="italic"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>