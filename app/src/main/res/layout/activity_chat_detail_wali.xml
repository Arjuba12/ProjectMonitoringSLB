<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout_wali"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC">

        <!-- Header -->
        <include
            android:id="@+id/toolbar_include"
            layout="@layout/toolbar_portal_wali" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="0"
            app:tint="#1E293B"
            android:layout_below="@id/toolbar_include"
            android:visibility="gone" />

        <!-- Chat Conversation Area -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar_include"
            android:layout_above="@id/input_area"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_chat_with"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bu Hartini — Wali Kelas"
                    android:textColor="#1E293B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp"/>

                <!-- Incoming Message -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chat_bubble_received"
                    android:padding="12dp"
                    android:layout_marginEnd="64dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Andi hari ini tampak lebih ceria dan aktif mengikuti kegiatan kelompok Bu."
                        android:textColor="#1E293B"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10.30"
                        android:textColor="#94A3B8"
                        android:textSize="10sp"
                        android:layout_gravity="start"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Outgoing Message -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_chat_bubble_sent"
                    android:padding="12dp"
                    android:layout_marginStart="64dp"
                    android:layout_gravity="end"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alhamdulillah senang mendengarnya. Terima kasih infonya Bu."
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11.11"
                        android:textColor="#E2E8F0"
                        android:textSize="10sp"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Input Area -->
        <LinearLayout
            android:id="@+id/input_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <EditText
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_chat"
                android:hint="Tulis Pesan..."
                android:paddingHorizontal="16dp"
                android:textSize="13sp" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_upload"
                android:padding="10dp"
                app:tint="#94A3B8" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="Kirim"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="#475569"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_wali"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:menu="@menu/drawer_menu_wali"
        app:headerLayout="@layout/nav_header_main" />

</androidx.drawerlayout.widget.DrawerLayout>