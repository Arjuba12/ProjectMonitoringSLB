<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tv_nama_harian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Andi Rizky"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"/>

        <TextView
            android:id="@+id/tv_aspek_harian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aspek: Kognitif"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:layout_marginTop="2dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F2F4F7"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_narasi_harian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sudah bisa menyebutkan 5 huruf vokal dengan bantuan minimal."
            android:textSize="13sp"
            android:textColor="#333333"
            android:lineSpacingExtra="2dp"/>

        <TextView
            android:id="@+id/tv_skor_harian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skor: 85"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="12dp"
            android:background="#E8F5E9"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>