<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:elevation="4dp">

    <View
        android:id="@+id/viewLogo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_circle_gray"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_bottom_toBottomOf="parent"
        android:backgroundTint="#2C3E50"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/viewLogo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_bottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PORTAL GURU"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SLB Generasi Emas"
            android:textSize="10sp"
            android:textColor="#95A5A6"
            android:textStyle="italic"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_rounded_gray"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:backgroundTint="#F2F4F7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_bottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bu Kartini"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_gray"
            android:backgroundTint="#BDC3C7"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>