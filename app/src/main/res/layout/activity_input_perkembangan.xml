<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Header -->
    <include layout="@layout/toolbar_portal" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Input Harian Siswa"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catat kehadiran dan perkembangan hari ini"
                android:textSize="12sp"
                android:textColor="#7F8C8D"
                android:layout_marginBottom="16dp"/>

            <!-- Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Utama" android:textSize="12sp" android:textStyle="bold" android:textColor="#2C3E50" android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pilih Siswa" android:textSize="11sp" android:textColor="#7F8C8D"/>
                            <Spinner
                                android:id="@+id/spinnerSiswa"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_rounded_gray"
                                android:backgroundTint="#F2F4F7"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tanggal" android:textSize="11sp" android:textColor="#7F8C8D"/>
                            <TextView
                                android:id="@+id/tvTanggal"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_rounded_gray"
                                android:backgroundTint="#F2F4F7"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:text="14/11/2024"
                                android:textSize="12sp"
                                android:textColor="#2C3E50"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F4F7" android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aspek Perkembangan (PPI)" android:textSize="12sp" android:textStyle="bold" android:textColor="#2C3E50" android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pilih Aspek" android:textSize="11sp" android:textColor="#7F8C8D"/>
                            <Spinner
                                android:id="@+id/spinnerAspek"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_rounded_gray"
                                android:backgroundTint="#F2F4F7"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Capaian (%)" android:textSize="11sp" android:textColor="#7F8C8D"/>
                            <EditText
                                android:id="@+id/etCapaian"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_rounded_gray"
                                android:backgroundTint="#F2F4F7"
                                android:layout_marginTop="4dp"
                                android:inputType="number"
                                android:paddingStart="12dp"
                                android:textSize="12sp"
                                android:hint="0-100"
                                android:textColorHint="#BDC3C7"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Catatan Observasi" android:textSize="11sp" android:textColor="#7F8C8D" android:layout_marginTop="16dp"/>
                    <EditText
                        android:id="@+id/etCatatan"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_rounded_gray"
                        android:backgroundTint="#F2F4F7"
                        android:gravity="top"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:textSize="12sp"
                        android:hint="Deskripsikan perkembangan anak..."/>

                    <Button
                        android:id="@+id/btnSimpan"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Simpan Data"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="#2C3E50"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Table History Today -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Riwayat Hari Ini"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:textColor="#2C3E50"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <TableLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:stretchColumns="*">

                        <TableRow
                            android:background="#2C3E50"
                            android:padding="2dp">
                            <TextView
                                android:minWidth="120dp"
                                android:padding="14dp"
                                android:text="Siswa"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="Aspek"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="Nilai"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </TableRow>

                        <TableRow android:padding="2dp">
                            <TextView
                                android:padding="14dp"
                                android:text="Andi Rizky"
                                android:textColor="#333333"
                                android:textSize="12sp" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="Kognitif"
                                android:textColor="#7F8C8D"
                                android:textSize="12sp" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="85%"
                                android:textColor="#2E7D32"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </TableRow>

                        <View
                            android:layout_height="1dp"
                            android:background="#F2F4F7" />

                        <TableRow android:padding="2dp">
                            <TextView
                                android:padding="14dp"
                                android:text="Budi Santoso"
                                android:textColor="#333333"
                                android:textSize="12sp" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="Motorik"
                                android:textColor="#7F8C8D"
                                android:textSize="12sp" />
                            <TextView
                                android:gravity="center"
                                android:padding="14dp"
                                android:text="70%"
                                android:textColor="#2E7D32"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </TableRow>

                    </TableLayout>
                </HorizontalScrollView>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>