<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout_perkembangan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp">

            <include layout="@layout/toolbar_portal_wali" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Riwayat Perkembangan Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Riwayat Perkembangan"
                                    android:textColor="#1E293B"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Statistik per semester"
                                    android:textColor="#64748B"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <Spinner
                                android:id="@+id/spinner_semester"
                                android:layout_width="160dp"
                                android:layout_height="38dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_spinner_semester"
                                android:paddingStart="12dp"
                                android:paddingEnd="36dp"
                                android:dropDownWidth="200dp"
                                android:overlapAnchor="false" />
                        </LinearLayout>


                        <!-- Professional Chart Implementation -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:orientation="horizontal"
                            android:paddingTop="8dp">

                            <!-- Y-Axis Scale Labels -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="end"
                                android:paddingEnd="8dp"
                                android:paddingStart="4dp"
                                android:layout_marginBottom="22dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="100" android:textSize="9sp" android:textColor="#BDC3C7"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="75" android:textSize="9sp" android:textColor="#BDC3C7"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="50" android:textSize="9sp" android:textColor="#BDC3C7"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:text="25" android:textSize="9sp" android:textColor="#BDC3C7"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="9sp" android:textColor="#BDC3C7"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <!-- Chart Area with Grid -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="bottom"
                                    android:background="@drawable/bg_chart_grid"
                                    android:paddingHorizontal="12dp"
                                    android:paddingBottom="2dp">

                                    <!-- Bar August -->
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="bottom|center_horizontal">
                                        <View
                                            android:id="@+id/bar_aug"
                                            android:layout_width="28dp"
                                            android:layout_height="0dp"
                                            android:background="@drawable/bg_chart_bar" />
                                    </LinearLayout>

                                    <!-- Bar September -->
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="bottom|center_horizontal">
                                        <View
                                            android:id="@+id/bar_sep"
                                            android:layout_width="28dp"
                                            android:layout_height="0dp"
                                            android:background="@drawable/bg_chart_bar" />
                                    </LinearLayout>

                                    <!-- Bar October -->
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="bottom|center_horizontal">
                                        <View
                                            android:id="@+id/bar_okt"
                                            android:layout_width="28dp"
                                            android:layout_height="0dp"
                                            android:background="@drawable/bg_chart_bar" />
                                    </LinearLayout>

                                    <!-- Bar November -->
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="bottom|center_horizontal">
                                        <View
                                            android:id="@+id/bar_nov"
                                            android:layout_width="28dp"
                                            android:layout_height="0dp"
                                            android:background="@drawable/bg_chart_bar" />
                                    </LinearLayout>

                                    <!-- Bar December -->
                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="bottom|center_horizontal">
                                        <View
                                            android:id="@+id/bar_des"
                                            android:layout_width="28dp"
                                            android:layout_height="0dp"
                                            android:background="@drawable/bg_chart_bar" />
                                    </LinearLayout>

                                </LinearLayout>

                                <!-- X-Axis Labels -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:orientation="horizontal"
                                    android:paddingHorizontal="4dp">

                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Agu" android:textColor="#95A5A6" android:textSize="10sp" android:textStyle="bold" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sep" android:textColor="#95A5A6" android:textSize="10sp" android:textStyle="bold" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Okt" android:textColor="#95A5A6" android:textSize="10sp" android:textStyle="bold" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Nov" android:textColor="#95A5A6" android:textSize="10sp" android:textStyle="bold" />
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Des" android:textColor="#95A5A6" android:textSize="10sp" android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Detail Per Aspek Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#FFFFFF">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="Detail per aspek"
                            android:textColor="#2C3E50"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none">

                            <TableLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:stretchColumns="0">

                                <!-- Header Table -->
                                <TableRow
                                    android:background="#F8F9FA"
                                    android:paddingVertical="8dp">
                                    <TextView
                                        android:text="Aspek"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Agu"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Sep"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Okt"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Nov"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Des"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Tren"
                                        android:textColor="#95A5A6"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>

                                <View android:layout_height="1dp" android:background="#ECF0F1" />

                                <!-- Row 1: Kognitif -->
                                <TableRow android:paddingVertical="10dp">
                                    <TextView
                                        android:text="Kognitif"
                                        android:textColor="#2C3E50"
                                        android:textSize="11sp"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="70%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="74%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="79%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="82%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="85%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Naik"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>

                                <View android:layout_height="1dp" android:background="#ECF0F1" />

                                <!-- Row 2: Sosial -->
                                <TableRow android:paddingVertical="10dp">
                                    <TextView
                                        android:text="Sosial"
                                        android:textColor="#2C3E50"
                                        android:textSize="11sp"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="65%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="68%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="72%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="75%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="78%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Naik"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>

                                <View android:layout_height="1dp" android:background="#ECF0F1" />

                                <!-- Row 3: Motorik -->
                                <TableRow android:paddingVertical="10dp">
                                    <TextView
                                        android:text="Motorik"
                                        android:textColor="#2C3E50"
                                        android:textSize="11sp"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="75%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="78%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="82%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="88%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="90%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Naik"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>

                                <View android:layout_height="1dp" android:background="#ECF0F1" />

                                <!-- Row 4: Komunikasi -->
                                <TableRow android:paddingVertical="10dp">
                                    <TextView
                                        android:text="Komunikasi"
                                        android:textColor="#2C3E50"
                                        android:textSize="11sp"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="72%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="75%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="78%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="80%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="82%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Naik"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>

                                <View android:layout_height="1dp" android:background="#ECF0F1" />

                                <!-- Row 5: Bina Diri -->
                                <TableRow android:paddingVertical="10dp">
                                    <TextView
                                        android:text="Bina Diri"
                                        android:textColor="#2C3E50"
                                        android:textSize="11sp"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="63%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="66%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="69%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="71%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="73%"
                                        android:textColor="#7F8C8D"
                                        android:textSize="11sp"
                                        android:gravity="center"
                                        android:paddingHorizontal="8dp" />
                                    <TextView
                                        android:text="Naik"
                                        android:textColor="#2E7D32"
                                        android:textSize="10sp"
                                        android:gravity="center"
                                        android:textStyle="bold"
                                        android:paddingHorizontal="8dp" />
                                </TableRow>
                            </TableLayout>
                        </HorizontalScrollView>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation_wali"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#FFFFFF"
            app:elevation="8dp"
            app:itemIconTint="@color/bnv_selector"
            app:itemTextColor="@color/bnv_selector"
            app:menu="@menu/bottom_nav_menu_wali" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Side Navigation -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_wali"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu_wali" />

</androidx.drawerlayout.widget.DrawerLayout>